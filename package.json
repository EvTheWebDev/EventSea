{
	"name": "eventsea",
	"private": true,
	"version": "0.0.1",
	"description": "An Event App Created by Ev Schmitt and Jeremy Black",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"mobile-build": "VITE_MOBILE_BUILD=true vite build",
		"mobile-sync": "npx cap sync",
		"ios:sync": "rm -rf build && npm run build:mobile && npx cap sync",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:seed": "node manageUsers.js seed",
		"db:clear": "node manageUsers.js clear"
	},
	"devDependencies": {
		"@capacitor/cli": "^8.2.0",
		"@iconify/svelte": "^5.1.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.47.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"svelte": "^5.41.0",
		"svelte-check": "^4.3.3",
		"typescript": "^5.9.3",
		"vite": "^7.1.10"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/EvTheWebDev/EventSea.git"
	},
	"bugs": {
		"url": "https://github.com/EvTheWebDev/EventSea/issues"
	},
	"homepage": "https://github.com/EvTheWebDev/EventSea#readme",
	"dependencies": {
		"@capacitor/android": "^8.2.0",
		"@capacitor/core": "^8.2.0",
		"@capacitor/ios": "^8.2.0",
		"firebase": "^12.6.0",
		"firebase-admin": "^13.6.1",
		"iconify-icon": "^3.0.2"
	}
}
